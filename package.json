{
  "name": "axiom-website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run property-api\"",
    "dev:restart": "powershell -ExecutionPolicy Bypass -Command \"Get-Process python* -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue; npm run dev:all\"",
    "build": "vite build",
    "preview": "vite preview",
    "property-api": "python -m uvicorn main:app --host 127.0.0.1 --port 8000 --app-dir services/property-api",
    "property-api:dev": "python -m uvicorn main:app --reload --reload-dir services/property-api --host 127.0.0.1 --port 8000 --app-dir services/property-api",
    "install:superpowers": "powershell -ExecutionPolicy Bypass -File scripts/install-superpowers.ps1"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "maplibre-gl": "^5.24.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.0"
  }
}
