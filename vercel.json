{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "AWS_LAMBDA_JS_RUNTIME": "nodejs22.x"
  },
  "functions": {
    "api/reports/pdf.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
